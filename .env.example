# Discord bot token. Never commit your real token.
DISCORD_TOKEN=your_bot_token_here

# Your Discord user ID. Enables owner-only /bot-stats and /bot-servers,
# plus direct notifications when the bot joins or leaves a server.
BOT_OWNER_ID=your_discord_user_id_here

# Public bot identity shown by H about and /about.
BOT_DEVELOPER_NAME=Hassaan
BOT_GITHUB_URL=https://github.com/thehoho/owo-boss-helper-discord-bot
BOT_SUPPORT_URL=
BOT_DESCRIPTION=OwO Boss Helper makes guild-boss fights easier by generating ordered Neon commands with live HP, tracking boss cooldowns and tickets, and saving guided team templates with exact weapon IDs.
